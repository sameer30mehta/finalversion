# PropScore — root environment example
# Copy to .env (gitignored) and customise. These values are read by both the
# backend (via backend/config.py + backend/db/sqlite.py) and the frontend
# (Vite — only the VITE_* keys are exposed to the browser).

# ─── Paths (portable defaults) ────────────────────────────────────────────
DATA_DIR=./data
DATABASE_URL=sqlite:///./data/propscore.sqlite
SQLITE_DB_PATH=./data/propscore.sqlite

# ─── Ollama (optional — rule-based fallback if not running) ──────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PRIMARY_MODEL=qwen2.5:7b
OLLAMA_FALLBACK_MODEL=llama3.2:3b
# Legacy aliases still honoured if you have them set:
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_FAST_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=150
OLLAMA_FAST_TIMEOUT_SECONDS=120
LLM_DEBUG=false

# ─── Hyperlocal Event Intelligence toggles ───────────────────────────────
ENABLE_LIVE_LOCALITY_SCAN=true
ENABLE_LOCALITY_CACHE=true

# ─── Vision (optional) ───────────────────────────────────────────────────
# Set ENABLE_VISION_MODEL=false on low-RAM machines if you don't need OWL-ViT.
# ENABLE_VISION_MODEL=true

# ─── Frontend (Vite) ─────────────────────────────────────────────────────
VITE_API_BASE_URL=http://127.0.0.1:8000
