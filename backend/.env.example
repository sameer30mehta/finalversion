# PropScore Backend Configuration
# Copy to backend/.env (gitignored) and customise. Identical to the root
# .env.example for the keys the backend uses — duplicated so you can keep a
# backend-specific override if you prefer.

# ─── Database (single SQLite file by default) ────────────────────────────
# Both the SQLAlchemy engine and the reference repositories default to the
# same SQLite file. They use disjoint table sets so they coexist cleanly.
# For a real Postgres deployment, swap DATABASE_URL (requires psycopg2-binary).
DATABASE_URL=sqlite:///./data/propscore.sqlite
# DATABASE_URL=postgresql://propscore:propscore@localhost:5432/propscore
SQLITE_DB_PATH=./data/propscore.sqlite

# ─── Ollama (optional) ───────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PRIMARY_MODEL=qwen2.5:7b
OLLAMA_FALLBACK_MODEL=llama3.2:3b
# Legacy aliases (backwards-compat):
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_FAST_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=150
OLLAMA_FAST_TIMEOUT_SECONDS=120
LLM_DEBUG=false
OLLAMA_VLM_MODEL=llava:7b
OLLAMA_TEXT_MODEL=llama2:7b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# ─── Models ──────────────────────────────────────────────────────────────
VISION_MODEL=google/owlvit-base-patch32
ENABLE_VISION_MODEL=true
CLIP_MODEL=openai/clip-vit-base-patch32
ONNX_NPU_MODEL_PATH=./models/npu/phi-mini.onnx
XGBOOST_MODEL_PATH=./models/xgboost/valuation_model.pkl

# ─── Paths (portable) ────────────────────────────────────────────────────
DATA_DIR=./data
MODELS_DIR=./models
INDEX_DIR=./indexes

# ─── Hyperlocal Event Intelligence toggles ───────────────────────────────
ENABLE_LIVE_LOCALITY_SCAN=true
ENABLE_LOCALITY_CACHE=true

# ─── Pipeline features ───────────────────────────────────────────────────
ENABLE_FRAUD_DETECTION=true
ENABLE_PARALLEL_INFERENCE=true
MAX_WORKERS=4
REQUEST_TIMEOUT=60

# ─── Demo / debug ────────────────────────────────────────────────────────
DEMO_MODE=false
USE_MOCK_MODELS=false
LOG_LEVEL=info

# ─── Frontend (Vite) — duplicated here for one-stop env copy ────────────
VITE_API_BASE_URL=http://127.0.0.1:8000
